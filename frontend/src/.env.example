# ==========================================
# Frontend Environment Variables (.env.example)
# Copy this file to .env and fill in the actual values.
# ==========================================

# ------------------------------------------
# API & Backend Connectivity
# ------------------------------------------
# The base URL for the backend API (e.g., http://localhost:8000/api/v1 for local dev)
VITE_API_URL=http://localhost:8000/api/v1

# The base URL for the backend server (used for Socket.io connections)
VITE_API_BASE_URL=http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000

# ------------------------------------------
# Authentication (Google OAuth)
# ------------------------------------------
# Get this from Google Cloud Console -> Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# ------------------------------------------
# Error Tracking (Sentry)
# ------------------------------------------
# Get this from your Sentry project settings
VITE_SENTRY_DSN=https://your_dsn_key@o0.ingest.sentry.io/0

# ------------------------------------------
# Payments (Razorpay)
# ------------------------------------------
# Get this from Razorpay Dashboard -> API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ------------------------------------------
# Firebase Configuration
# ------------------------------------------
# Get these from Firebase Console -> Project Settings -> General
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
